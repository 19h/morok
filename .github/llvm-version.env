# Pinned official LLVM release whose prebuilt toolchain Morok's CI uses.
#
# Morok targets the New-PM plugin API at <llvm/Plugins/PassPlugin.h> with
# LLVM_PLUGIN_API_VERSION 2 (introduced by llvm/llvm-project#173279). That landed
# in the 22.x release series, so the official prebuilt 22.x toolchains build and
# load the plugin without any source changes. Toolchains are downloaded from
#   https://github.com/llvm/llvm-project/releases/tag/llvmorg-${LLVM_VERSION}
# (LLVM-<ver>-{Linux,macOS}-* and clang+llvm-<ver>-*-windows-msvc), verified by
# the release asset's sha256 digest.
#
# Bumped by .github/workflows/llvm-bump.yml as new LLVM releases ship.
LLVM_VERSION=22.1.8
